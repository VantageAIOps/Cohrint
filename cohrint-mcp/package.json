{
  "name": "cohrint-mcp",
  "version": "1.1.1",
  "description": "MCP server for Cohrint — track LLM costs and query analytics from Claude Desktop, Cursor, Windsurf, VS Code and more",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cohrint-mcp": "dist/index.js"
  },
  "scripts": {
    "gen-version": "node --input-type=commonjs -e \"const fs=require('fs');const v=require('./package.json').version;fs.writeFileSync('src/_version.ts','// AUTO-GENERATED — do not edit manually. Run: npm run gen-version\\nexport const VERSION = '+JSON.stringify(v)+';\\n');\"",
    "prebuild": "npm run gen-version",
    "build": "tsc && cp ../claude-intelligence/hooks/cohrint-track.js dist/cohrint-track.js",
    "predev": "npm run gen-version",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "pretest": "npm run build",
    "test": "node --test 'test/*.test.mjs'",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "llm",
    "cost",
    "analytics",
    "vantage",
    "ai",
    "openai",
    "anthropic",
    "claude",
    "cursor",
    "windsurf"
  ],
  "homepage": "https://cohrint.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/Amanjain98/VantageAI"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
