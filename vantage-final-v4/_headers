/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

/app.html
  Cache-Control: no-cache, no-store, must-revalidate
  Content-Security-Policy: default-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://fonts.gstatic.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://static.cloudflareinsights.com; connect-src 'self' https://api.vantageaiops.com wss://api.vantageaiops.com https://cloudflareinsights.com https://*.workers.dev; img-src 'self' data:; worker-src 'self';

/app
  Cache-Control: no-cache, no-store, must-revalidate
  Content-Security-Policy: default-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://fonts.gstatic.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://static.cloudflareinsights.com; connect-src 'self' https://api.vantageaiops.com wss://api.vantageaiops.com https://cloudflareinsights.com https://*.workers.dev; img-src 'self' data:; worker-src 'self';

/index.html
  Cache-Control: no-cache, no-store, must-revalidate

/calculator.html
  Cache-Control: public, max-age=3600

/docs.html
  Cache-Control: public, max-age=3600

/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Service-Worker-Allowed: /

/sitemap.xml
  Cache-Control: public, max-age=3600
  Content-Type: application/xml

/robots.txt
  Cache-Control: public, max-age=3600
