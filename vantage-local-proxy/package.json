{
  "name": "vantageai-local-proxy",
  "version": "1.0.1",
  "description": "Secure local proxy for LLM cost tracking — keeps API keys and prompts local, sends only anonymized stats to VantageAI dashboard",
  "keywords": ["ai", "llm", "proxy", "privacy", "cost-tracking", "openai", "anthropic"],
  "homepage": "https://vantageaiops.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/Amanjain98/VantageAI"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "vantage-proxy": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm,cjs --dts --clean",
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  },
  "engines": { "node": ">=18.0.0" }
}
