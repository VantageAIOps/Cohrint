{
  "name": "vantageai",
  "version": "1.0.0",
  "description": "Cohrint — AI Cost Intelligence Platform",
  "private": true,
  "scripts": {
    "dev": "wrangler pages dev --port=8788 --live-reload",
    "deploy": "wrangler pages deploy ./vantage-final-v4 --project-name=vantageai",
    "deploy:preview": "wrangler pages deploy ./vantage-final-v4 --project-name=vantageai --branch=preview",
    "deploy:prod": "wrangler pages deploy ./vantage-final-v4 --project-name=vantageai --branch=main",
    "logs": "wrangler pages deployment tail --format=pretty",
    "deployments": "wrangler pages deployment list",
    "login": "wrangler login",
    "whoami": "wrangler whoami",
    "check": "node -e \"const h=['index.html','app.html','auth.html','calculator.html','docs.html','signup.html'].map(f=>require('fs').existsSync('./vantage-final-v4/'+f));console.log('Files:',h.every(Boolean)?'✓ all present':'✗ missing files');\"",
    "test": "python3 tests/run_suite.py --fast --no-report",
    "test:all": "python3 tests/run_suite.py --all --fast --no-report",
    "test:ci": "HEADLESS=1 python3 tests/run_suite.py --fast --no-report",
    "test:smoke": "curl -sf https://api.cohrint.com/v1/health | python3 -c \"import sys,json;d=json.load(sys.stdin);print('API:',d.get('status','ok'))\" && curl -sf -o /dev/null -w 'Frontend: HTTP %{http_code}\\n' https://cohrint.com/"
  },
  "devDependencies": {
    "wrangler": "^3.101.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
