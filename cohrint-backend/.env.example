# Vantage AI Server — Environment Variables
# Copy to .env and fill in your values

# Supabase (required for production)
SUPABASE_URL=https://oyljzpvwdfktrkeotmon.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Anthropic (for Claude Opus 4.6 hallucination evaluation)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Evaluation settings
EVAL_ENABLED=true
EVAL_SAMPLE_RATE=0.2   # evaluate 20% of events (cost saving)
EVAL_MODEL=claude-opus-4-6  # change to another Anthropic eval model if available

# Server
PORT=8000
LOG_LEVEL=info
