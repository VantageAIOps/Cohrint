{
  "name": "vantage-worker",
  "version": "1.0.0",
  "description": "VantageAI ingest + analytics API — Cloudflare Worker",
  "private": true,
  "scripts": {
    "dev":     "wrangler dev",
    "deploy":  "wrangler deploy",
    "types":   "wrangler types",
    "db:create":  "wrangler d1 create vantage-events",
    "db:migrate": "wrangler d1 execute vantage-events --file=schema.sql",
    "db:migrate:remote": "wrangler d1 execute vantage-events --remote --file=schema.sql",
    "kv:create":  "wrangler kv:namespace create VANTAGE_KV"
  },
  "dependencies": {
    "hono": "^4.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240725.0",
    "typescript": "^5.4.0",
    "wrangler": "^3.60.0"
  }
}
