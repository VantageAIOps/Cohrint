{
  "name": "cohrint-cli",
  "version": "2.2.5",
  "description": "Cohrint CLI — AI cost tracking and optimization tool",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "cohrint": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --no-splitting",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "esbuild": "0.27.4",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
